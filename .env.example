# .env.example - generated with dotenvx

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=
# Set by hosting platform (e.g. Render) — leave blank for local development
SERVER_BASE_URL=

# ─── API Versioning ─────────────────────────────────────────────────────────────
# Overrides the default active version. Must be a value in SUPPORTED_VERSIONS.
API_VERSION=

# ─── Logging ────────────────────────────────────────────────────────────────────
# Allowed values: SILENT | ERROR | WARN | INFO | DEBUG | VERBOSE
LOG_LEVEL=
LOG_LEVEL_HANTEO=
LOG_LEVEL_CIRCLE=
